# Copy to .env and fill in values. Do not commit .env.

# Source / default cwd for local run() (align with RELEASE_WORKDIR if the bot only serves one clone).
REPO_PATH=

PORT=8787
AGENT_TOKEN=

# Feishu bot
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Release clone + deploy (paths on the build machine)
RELEASE_REPO_URL=
# monorepo 根目录绝对路径。发布/部署逻辑一律运行时读 process.env（勿依赖「启动时空串」）。
RELEASE_WORKDIR=
RELEASE_BRANCH=main
RELEASE_CONFIRM_TOKEN=

# 修改 RELEASE_MODULES_JSON / 其它 .env 后须重启 release-bot（如 pnpm run restart:env），dotenv 只在进程启动时加载一次。
#
# Cursor：Agent 会话结束（stop 钩子）时是否后台请求本机 http://127.0.0.1:$PORT/run 执行「发布 全部」
#（需本机已 pm2/tsx 跑起 release-bot，且 AGENT_TOKEN / RELEASE_CONFIRM_TOKEN 与 .env 一致）。日志：.cursor/auto-release.log
RELEASE_AUTO_FULL_RELEASE_ON_AGENT_STOP=

# SSH deploy target
DEPLOY_HOST=
DEPLOY_USER=root
SSH_PORT=22

# When not "false": before rsync, mirror current remote deploy dir to `<deployPath>.release-bot-prev`;
# on deploy/postDeploy/restart failure, restore from that mirror and restart (see README 部署失败与回滚).
RELEASE_AUTO_ROLLBACK_ON_DEPLOY_FAIL=

# Default fallbacks when a module omits fields in RELEASE_MODULES_JSON
DEPLOY_PATH=
INSTALL_CMD=pnpm install --frozen-lockfile
# Monorepo: build all workspace packages once after install, before each app (see release.service releasePipeline).
# Example (Turborepo): RELEASE_PACKAGES_BUILD_CMD=pnpm exec turbo run build --filter=./packages/*
RELEASE_PACKAGES_BUILD_CMD=
BUILD_CMD=pnpm build
BUILD_ARTIFACT_PATH=dist
REMOTE_RESTART_CMD=

# rsync 默认再排除 infra 基线（ecosystem.config.cjs、docker-compose、Caddy、caddy.d/、scripts/），
# 避免产物误带这些文件覆盖服务器上由 sentinel-infra 长期维护的内容。设为 false 则仅排除 .env*。
RELEASE_RSYNC_INFRA_EXCLUDES=

# Per-module JSON. deployPath 须与服务器目录及 PM2 cwd 一致（见下「sentinel-infra 布局」）。
#
# For Node apps that require workspace packages (@sentinel/*), either build a self-contained
# artifact (pnpm deploy / Docker) or add rsyncExtras to sync built packages after the main artifact, e.g.:
#   "rsyncExtras":[
#     {"from":"packages/auth","to":"node_modules/@sentinel/auth"},
#     {"from":"packages/database","to":"node_modules/@sentinel/database"},
#     {"from":"packages/security-sdk","to":"node_modules/@sentinel/security-sdk"}
#   ]
# (release-bot uses rsync -L on extras so @prisma/client symlinks under packages/database resolve.)
#
# main-next (Next standalone): use the monorepo script — buildCmd "pnpm --filter ./apps/main-next run build:release"
# and artifactPath "apps/main-next/.release" (do not use manual cp from .next/standalone or test -f .release/server.js;
# standalone layout may nest server.js under apps/main-next/).
# Adjust `from` to directories that exist after your preBuildCmd/buildCmd (must include package.json + dist).
#
# 主产物与 rsyncExtras 均排除 .env / .env.production 等；请在服务器上单独维护 deployPath 下的生产环境变量。
#
# server / Prisma: do NOT npm install inside deploy dir if package.json still has workspace: refs (npm errors EUNSUPPORTEDPROTOCOL).
# 推荐：在 RELEASE_MODULES_JSON 的 server（等）模块上设 rewriteWorkspaceDepsInPackageJson: true，
# release-bot 会在本机 rsync 之前直接改写产物与 rsyncExtras 源目录里的 package.json（file:database / file:./security-sdk → file:./node_modules/@sentinel/…；workspace:* 与 pnpm catalog: 按 map 替换；递归处理 npm overrides 与 pnpm.overrides；strip 时去掉 pnpm 块），再上传；不依赖远端 SSH 执行 node。
# 若 artifact 仅为 apps/server/dist 且 dist 内无 package.json，会改写上级 apps/server/package.json 并复制进 dist，否则远端永远收不到已改写的依赖。
# 勿在 postDeployCmd 里再写 node -e。
# 若仍保留 node -e，部署前会失败；仅当你确认引号绝对安全时可设 RELEASE_ALLOW_POSTDEPLOY_NODE_EVAL=true 跳过检查。
#（经 ssh 与 bash -lc 嵌套后双引号常被剥掉，会出现 require(fs)、Invalid regular expression flags）。
# 仍可选：由 monorepo 打出已替换 file: 的 package.json；或在 postDeployCmd 里只写 npm install / pm2（单引号包一层即可）。
# postDeployCmd 经 ssh + shellEscape（外层单引号）。避免 bash -lc "..." 再嵌 node -e "..."；若必须手写 node，用服务器上的 .sh 脚本文件。
# Use a clean temp dir + absolute --schema for prisma generate, e.g.:
#   rm -rf /tmp/sentinel-prisma-gen && mkdir /tmp/sentinel-prisma-gen && cd /tmp/sentinel-prisma-gen && npm init -y && \
#     npm install prisma@X.Y.Z && node node_modules/prisma/build/index.js generate \
#     --schema=/root/sentinel-infra/server/node_modules/@sentinel/database/prisma/schema.prisma
# Do NOT `cd` into node_modules/@sentinel/database and run prisma there: pnpm hoists @prisma/engines-version to another
# .pnpm folder, so the nested prisma under the synced package is incomplete and throws MODULE_NOT_FOUND on Linux.
# Build machine can stay macOS; npx downloads a full Prisma CLI on the server.
# pnpm 产物 + 远端 npm install 易报 matches / cp 断链：推荐 server 模块设 cleanRemoteNodeModulesAndResyncExtrasBeforePostDeploy: true，
# release-bot 会在本机先改写好 deploy 产物与 rsyncExtras 源包里的 package.json，再 rsync；远端若启用 cleanRemoteNodeModulesAndResyncExtrasBeforePostDeploy，则 rm node_modules 后第二次 extras 仍从已改写的本机目录同步。
# 然后内置远端 prisma，最后 postDeploy 只需 npm install。
# 若关闭 RELEASE_REMOTE_PRISMA_GENERATE，须在 postDeploy 里自行 prisma generate（schema 在 node_modules/@sentinel/database）。
# 注意：bash -lc "…" 双引号内 $VAR 会提前展开，勿在 postDeploy 里用未赋值的 $T。
#
# --- Sentinel-style checklist (release-bot + monorepo) ---
# 1) main-next: ship official standalone (.release via build:release + pack-standalone); do not rsync raw pnpm symlinks.
#    PM2: 需要 Redis/JWT 等时勿只 start server.js（会丢 ecosystem 里的 env）。应用 deployRoot 的 ecosystem：
#    `cd /root/sentinel-infra && pm2 start ecosystem.config.cjs --only sentinel-next` 或 `./scripts/pm2-reload-all.sh`。
#    delete 后再 start 可避免 `restart` 卡在 errored；standalone-host.cjs 若存在仍以 ecosystem 为准。
#    Optional: pack-standalone can add standalone-host.cjs next to server.js if you want that entry instead.
#    remoteRestartCmd can be bash -lc ":" if restart is already in postDeployCmd.
# 2) @sentinel/database: build should include prisma generate (e.g. "build": "prisma generate && tsc") so Next build resolves @prisma/client.
# 3) server: rsyncExtras for auth/database/security-sdk; postDeploy prisma generate on Linux; server .env.production on host (REDIS_URL must match infra).
#    Static apps (sub-react/sub-vue): 与 ecosystem 中 static-serve 一致时仅需 rsync dist + remoteRestartCmd pm2 restart sentinel-sub-*，勿装 serve。
# 4) PM2: NODE_ENV=production for API (ecosystem); release-bot can export HOST/HOSTNAME/PORT on start.
# release-bot runs `server` deploy before other modules when `server` is in the release set.
#
# Prisma on the deploy host: after rsync+extras on the server module, optionally run an extra
# `prisma generate` (tmp-dir pattern above). main-next: API 目录 prisma generate 后，release-bot 会把
# `.prisma/client` 复制进 main-next 的 `@sentinel/database`（standalone 无需带 schema），再执行 postDeploy/sync。
# Set RELEASE_REMOTE_PRISMA_GENERATE=false to skip only the server-module extra step.
RELEASE_REMOTE_PRISMA_GENERATE=
# Remote absolute path to the API (server) deploy dir — optional if server.deployPath is set in
# RELEASE_MODULES_JSON. Example: /root/sentinel-infra/server
REMOTE_PRISMA_SERVER_DEPLOY_PATH=
# Optional overrides (defaults are safe for sentinel-monorepo layout):
# REMOTE_PRISMA_SCHEMA_REL=node_modules/@sentinel/database/prisma/schema.prisma
# REMOTE_PRISMA_GEN_TMP=/tmp/sentinel-prisma-gen
# Pin Prisma CLI on the host: bare `prisma` resolves to v7+ and breaks Prisma 6-style schemas (P1012).
# REMOTE_PRISMA_CLI_PACKAGE=prisma@6.2.1
# REMOTE_PRISMA_GENERATE_DATABASE_URL=postgresql://127.0.0.1:5432/__prisma_generate_only__
#
# 可选：覆盖 workspace: -> file: 映射（JSON）。不设时默认 file:./node_modules/@sentinel/{auth,database,security-sdk}。
# vendor-sentinel 与 server 同级时示例：
# RELEASE_WORKSPACE_DEPS_REWRITE_JSON={"@sentinel/auth":"file:../vendor-sentinel/auth","@sentinel/database":"file:../vendor-sentinel/database","@sentinel/security-sdk":"file:../vendor-sentinel/security-sdk"}
#
# --- sentinel-infra 布局（与 PM2 ecosystem / 发包规范一致）---
# 服务器 deployRoot 示例：/root/sentinel-infra（勿把 .env、ecosystem.config.cjs 打进产物；release-bot 也不会用 rsync 覆盖它们）。
# PM2 应用名与 ecosystem.config.cjs 对齐：sentinel-api（cwd server）、sentinel-next（main-next/server.js）、
# sentinel-sub-react / sentinel-sub-vue（scripts/static-serve.cjs + 端口参数，无需 npm serve）。
# 每轮发布替换的目录与 monorepo .release 产物树同级对应：vendor-sentinel、server、main-next、sub-react、sub-vue。
# 部署顺序：含 vendor-sentinel 时先同步 vendor，再 server，再其余模块（保证 file:../vendor-sentinel 已就位）。
# 发版后重启建议：在服务器 deployRoot 下放 scripts/pm2-reload-all.sh（不被 rsync 覆盖），例如：
#   #!/bin/bash
#   set -e
#   cd /root/sentinel-infra
#   pm2 startOrReload ecosystem.config.cjs --update-env && pm2 save
# 各模块 postDeployCmd 可共用：bash -lc 'cd /root/sentinel-infra && ./scripts/pm2-reload-all.sh'
# remoteRestartCmd 若已在 postDeploy 里 reload，可写 bash -lc ':'。
# REMOTE_PRISMA_SERVER_DEPLOY_PATH=/root/sentinel-infra/server
#
# 示例（请按 monorepo 实际 build 输出改 artifactPath / buildCmd）：
# RELEASE_MODULES_JSON={
#   "vendor-sentinel": {
#     "deployPath": "/root/sentinel-infra/vendor-sentinel",
#     "artifactPath": ".release/vendor-sentinel",
#     "buildCmd": "bash scripts/build-release.sh",
#     "postDeployCmd": "bash -lc 'cd /root/sentinel-infra && ./scripts/pm2-reload-all.sh'",
#     "remoteRestartCmd": "bash -lc ':'"
#   },
#   "server": {
#     "deployPath": "/root/sentinel-infra/server",
#     "artifactPath": ".release/server",
#     "buildCmd": "bash scripts/build-release.sh",
#     "rewriteWorkspaceDepsInPackageJson": true,
#     "cleanRemoteNodeModulesAndResyncExtrasBeforePostDeploy": true,
#     "rsyncExtras": [ ... ],
#     "postDeployCmd": "bash -lc 'cd /root/sentinel-infra/server && rm -f package-lock.json && npx -y npm@9.9.4 install --omit=dev --legacy-peer-deps && cd /root/sentinel-infra && ./scripts/pm2-reload-all.sh'",
#     "remoteRestartCmd": "bash -lc ':'"
#   },
#   "main-next": {
#     "deployPath": "/root/sentinel-infra/main-next",
#     "artifactPath": ".release/main-next",
#     "buildCmd": "bash scripts/build-release.sh",
#     "postDeployCmd": "bash -lc 'cd /root/sentinel-infra && ./scripts/pm2-reload-all.sh'",
#     "remoteRestartCmd": "bash -lc ':'"
#   },
#   "sub-react": {
#     "deployPath": "/root/sentinel-infra/sub-react",
#     "artifactPath": ".release/sub-react",
#     "buildCmd": "bash scripts/build-release.sh",
#     "postDeployCmd": "bash -lc 'cd /root/sentinel-infra && ./scripts/pm2-reload-all.sh'",
#     "remoteRestartCmd": "bash -lc ':'"
#   },
#   "sub-vue": {
#     "deployPath": "/root/sentinel-infra/sub-vue",
#     "artifactPath": ".release/sub-vue",
#     "buildCmd": "bash scripts/build-release.sh",
#     "postDeployCmd": "bash -lc 'cd /root/sentinel-infra && ./scripts/pm2-reload-all.sh'",
#     "remoteRestartCmd": "bash -lc ':'"
#   }
# }
RELEASE_MODULES_JSON={}
