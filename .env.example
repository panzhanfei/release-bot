# Copy to .env and fill in values. Do not commit .env.

PORT=8787
AGENT_TOKEN=

# Feishu bot
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Release clone + deploy (paths on the build machine)
RELEASE_REPO_URL=
RELEASE_WORKDIR=
RELEASE_BRANCH=main
RELEASE_CONFIRM_TOKEN=

# SSH deploy target
DEPLOY_HOST=
DEPLOY_USER=root
SSH_PORT=22

# Default fallbacks when a module omits fields in RELEASE_MODULES_JSON
DEPLOY_PATH=
INSTALL_CMD=pnpm install --frozen-lockfile
# Monorepo: build all workspace packages once after install, before each app (see release.service releasePipeline).
# Example (Turborepo): RELEASE_PACKAGES_BUILD_CMD=pnpm exec turbo run build --filter=./packages/*
RELEASE_PACKAGES_BUILD_CMD=
BUILD_CMD=pnpm build
BUILD_ARTIFACT_PATH=dist
REMOTE_RESTART_CMD=

# Per-module JSON. Use deployPath that matches the SERVER filesystem and PM2 cwd
# (e.g. /root/srv/sentinel/server — not a stale /srv/sentinel if you actually deploy under root).
#
# For Node apps that require workspace packages (@sentinel/*), either build a self-contained
# artifact (pnpm deploy / Docker) or add rsyncExtras to sync built packages after the main artifact, e.g.:
#   "rsyncExtras":[
#     {"from":"packages/auth","to":"node_modules/@sentinel/auth"},
#     {"from":"packages/database","to":"node_modules/@sentinel/database"},
#     {"from":"packages/security-sdk","to":"node_modules/@sentinel/security-sdk"}
#   ]
# (release-bot uses rsync -L on extras so @prisma/client symlinks under packages/database resolve.)
#
# main-next (Next standalone): use the monorepo script — buildCmd "pnpm --filter ./apps/main-next run build:release"
# and artifactPath "apps/main-next/.release" (do not use manual cp from .next/standalone or test -f .release/server.js;
# standalone layout may nest server.js under apps/main-next/).
# Adjust `from` to directories that exist after your preBuildCmd/buildCmd (must include package.json + dist).
#
# 主产物与 rsyncExtras 均排除 .env / .env.production 等；请在服务器上单独维护 deployPath 下的生产环境变量。
# 可参考仓库内 .secrets/sentinel-server.env.production.example（仅作字段说明，release-bot 不会上传该文件）。
#
# server / Prisma: do NOT npm install inside deploy dir if package.json uses pnpm workspace: (npm errors EUNSUPPORTEDPROTOCOL).
# Use a clean temp dir + absolute --schema, e.g.:
#   rm -rf /tmp/sentinel-prisma-gen && mkdir /tmp/sentinel-prisma-gen && cd /tmp/sentinel-prisma-gen && npm init -y && \
#     npm install prisma@X.Y.Z && node node_modules/prisma/build/index.js generate \
#     --schema=/root/srv/sentinel/server/node_modules/@sentinel/database/prisma/schema.prisma
# Do NOT `cd` into node_modules/@sentinel/database and run prisma there: pnpm hoists @prisma/engines-version to another
# .pnpm folder, so the nested prisma under the synced package is incomplete and throws MODULE_NOT_FOUND on Linux.
# Build machine can stay macOS; npx downloads a full Prisma CLI on the server.
#
# --- Sentinel-style checklist (release-bot + monorepo) ---
# 1) main-next: ship official standalone (.release via build:release + pack-standalone); do not rsync raw pnpm symlinks.
#    PM2: prefer `pm2 delete sentinel-next; export HOST=0.0.0.0 HOSTNAME=0.0.0.0 PORT=3000 NODE_ENV=production; pm2 start .../server.js`
#    after sync script — avoids `restart` leaving an `errored` process and avoids starting a missing standalone-host.cjs.
#    Optional: pack-standalone can add standalone-host.cjs next to server.js if you want that entry instead.
#    remoteRestartCmd can be bash -lc ":" if restart is already in postDeployCmd.
# 2) @sentinel/database: build should include prisma generate (e.g. "build": "prisma generate && tsc") so Next build resolves @prisma/client.
# 3) server: rsyncExtras for auth/database/security-sdk; postDeploy prisma generate on Linux; server .env.production on host (REDIS_URL must match infra).
# 4) PM2: NODE_ENV=production for API (ecosystem); release-bot can export HOST/HOSTNAME/PORT on start.
# release-bot runs `server` deploy before other modules when `server` is in the release set.
RELEASE_MODULES_JSON={}
