# Reference only: edit `{deployPath}/.env.production` on the server (release-bot does not upload env).
# Matches apps/server src config (Zod). NODE_ENV=production loads this file name.

NODE_ENV=production
PORT=4000

# Required (no default / min length)
DEEPSEEK_API_KEY=your-deepseek-key
REDIS_URL=redis://:password@127.0.0.1:6379/0

# Defaults exist in schema but set explicitly in production
JWT_SECRET=change-me-min-32-chars-long-secret-key
REFRESH_TOKEN_SECRET=change-me-another-32-chars-refresh-secret

# CORS: your real main site origin(s)
CORS_ORIGIN=https://your-domain.com

# Anvil: on server, often Docker/Caddy — use reachable URL for the API process
ANVIL_RPC_URL=http://127.0.0.1:8545

# Optional Telegram / proxy
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_HTTPS_PROXY=
